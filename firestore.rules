rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function isDocOwner() {
      return isAuthenticated() && 
             resource != null && 
             'uid' in resource.data && 
             resource.data.uid == request.auth.uid;
    }

    function isNewDocOwner() {
      return isAuthenticated() && 
             request.resource != null && 
             'uid' in request.resource.data && 
             request.resource.data.uid == request.auth.uid;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "beingphileas@gmail.com" && request.auth.token.email_verified == true));
    }

    function uidUnchanged() {
      return !('uid' in request.resource.data) || request.resource.data.uid == request.auth.uid;
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================
    function isValidDrink(data) {
      return data.brand is string && data.brand.size() > 0 && data.brand.size() < 200 &&
             data.name is string && data.name.size() > 0 && data.name.size() < 200 &&
             data.category in ['Wine', 'Beer', 'Gin', 'Whiskey', 'Cognac', 'Rum'] &&
             (!('year' in data) || data.year is number) &&
             data.qualityScore is number && data.qualityScore >= 0 && data.qualityScore <= 100;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isOwner(userId);
      allow write: if isOwner(userId);
    }

    match /drinks/{drinkId} {
      allow read: if isDocOwner();
      allow create: if isAuthenticated() && uidUnchanged() && isValidDrink(request.resource.data);
      allow update: if isDocOwner() && uidUnchanged() && isValidDrink(request.resource.data);
      allow delete: if isDocOwner();
    }

    match /merchants/{merchantId} {
      allow read: if isDocOwner();
      allow create: if isAuthenticated() && uidUnchanged();
      allow update: if isDocOwner() && uidUnchanged();
      allow delete: if isDocOwner();
    }

    match /tasks/{taskId} {
      allow read: if isDocOwner();
      allow create: if isAuthenticated() && uidUnchanged();
      allow update: if isDocOwner() && uidUnchanged();
      allow delete: if isDocOwner();
    }

    match /drink_lists/{listId} {
      allow read: if isDocOwner();
      allow create: if isAuthenticated() && uidUnchanged();
      allow update: if isDocOwner() && uidUnchanged();
      allow delete: if isDocOwner();
    }
  }
}
